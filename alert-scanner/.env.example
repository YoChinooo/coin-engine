# ─── Coin Engine Alert Scanner — Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# On Railway / Render, add these as service Variables (no .env file needed).

# ── Notification provider ─────────────────────────────────────────────────────
# Choose one: ntfy | telegram | none
NOTIFY_PROVIDER=ntfy

# ntfy.sh settings (if NOTIFY_PROVIDER=ntfy)
# Use the same topic you configured in the app's Phone Alert settings.
NTFY_TOPIC=your-topic-here
NTFY_SERVER=https://ntfy.sh

# Telegram settings (if NOTIFY_PROVIDER=telegram)
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUVwxyz
TELEGRAM_CHAT_ID=987654321

# ── Symbols to watch ──────────────────────────────────────────────────────────
# Comma-separated Yahoo Finance tickers.
# Futures: ES=F  NQ=F  CL=F  GC=F  SI=F  NG=F  ZB=F
# Crypto:  BTC-USD  ETH-USD  SOL-USD  DOGE-USD
# Stocks:  AAPL  TSLA  SPY  QQQ
WATCH_SYMBOLS=ES=F,NQ=F,BTC-USD,ETH-USD,SOL-USD

# ── Thresholds ────────────────────────────────────────────────────────────────
MIN_WIN_PROB=65
NOTIFY_LONG=true
NOTIFY_SHORT=true

# Early action meme coin / crypto alerts
NOTIFY_EARLY_CRYPTO=true
EARLY_SCORE_THRESHOLD=80

# ── Intervals (milliseconds) ──────────────────────────────────────────────────
WATCH_INTERVAL_MS=90000    # 90 seconds
EARLY_INTERVAL_MS=300000   # 5 minutes
RATE_LIMIT_MS=600000       # 10 min per symbol between alerts

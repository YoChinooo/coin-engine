{
  "installCommand": "npm install",
  "buildCommand": "node node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "functions": {
    "api/yahoo.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/yf/:path*",
      "destination": "https://query1.finance.yahoo.com/:path*"
    },
    {
      "source": "/yf2/:path*",
      "destination": "https://query2.finance.yahoo.com/:path*"
    },
    {
      "source": "/cg/:path*",
      "destination": "https://api.coingecko.com/api/v3/:path*"
    }
  ]
}
